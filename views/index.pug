extends layout

block content
  h1= title
  p Welcome to #{title}
  ol
  each val in todos
    li
      span= val.task + ' - '
      if val.completed
        span.completed-text Completed
      else
        span.not-completed-text Not Completed

    // Generated by ChatGPT
    // Buttons row
    div(style="margin-top:5px;")
        
      // ✅ Complete button
      if !val.completed
        form(method='POST', action='/complete', style='display:inline; margin-right:5px;')
          input(type='hidden', name='id', value=val.id)
          button(type='submit') Complete

      // ✅ Delete button
      form(method='POST', action='/delete', style='display:inline; margin-right:5px;')
        input(type='hidden', name='id', value=val.id)
        button(type='submit') Delete

      // ✅ Edit form (on its own line)
      div(style="margin-top:5px;")
        form(method='POST', action='/edit')
          input(type='hidden', name='id', value=val.id)
          input(type='text', name='task', placeholder='Edit task', required)
          button(type='submit') Edit
          // End of ChatGPT Generation

  hr
  h2 Add a new task
  form(method='POST' action='/create')
    label(for='task') Task:
    input(type='text', name='task', id='task', required)
    button(type='submit') Create Task

  
